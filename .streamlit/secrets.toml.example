# Streamlit Secrets 配置文件示例
# 复制此文件为 secrets.toml 并填入实际的 API Key
# 注意: secrets.toml 已被添加到 .gitignore，不会被提交到版本控制

[keys]
# 阿里云百炼 DashScope API Key
# 申请地址: https://dashscope.console.aliyun.com/
dashscope_api_key = "your_dashscope_api_key_here"

# SearchAPI Key (百度搜索)
# 申请地址: https://www.searchapi.io/
searchapi_api_key = "your_searchapi_api_key_here"

# Serper API Key (Google 搜索)
# 申请地址: https://serper.dev
# serper_api_key = "your_serper_api_key_here"

# Tavily API Key (AI 搜索)
# 申请地址: https://tavily.com
# tavily_api_key = "your_tavily_api_key_here"

# SerpAPI Key (Google 搜索)
# 申请地址: https://serpapi.com
# serpapi_api_key = "your_serpapi_api_key_here"
